{
  "expo": {
    "name": "PixelLift",
    "slug": "pixel-lift",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pixellift",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.pixellift"
    },
    "android": {
      "package": "com.yourname.pixellift"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
